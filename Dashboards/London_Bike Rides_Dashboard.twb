      </column>
      <column caption='In Range Rides' datatype='integer' name='[Calculation_3054764870672392]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ SUM(INT([Calculation_3054764869804039]) * [count]) }' />
